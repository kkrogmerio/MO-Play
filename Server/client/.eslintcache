ame]=useState(\"\");\r\n    let welcomed=0;\r\n    useEffect(()=> {\r\n        if(localStorage.getItem('onceWelcome')!=null)\r\n        {\r\n            localStorage.setItem('onceWelcome',0)\r\n        }\r\n        if(localStorage.getItem('onceWelcome')==null)\r\n        {\r\n\r\n            localStorage.setItem('onceWelcome',1)\r\n        }\r\n\r\n    },[])\r\n\r\n\r\n    axios.get(`${process.env.REACT_APP_API_URL}/getData`, {\r\n\r\n        withCredentials: true\r\n    }).then(res => {\r\n        console.log(\"DAAAAAAAAAAAAAAAAAAAAAAAA//\")\r\n        console.log(res.data.name+\"BRRRRRRRRRRRRRRRRRRRRRRRRRRRR\");\r\n        setUsername(res.data.name);\r\n\r\n\r\n\r\n    });\r\n\r\n    return(\r\n        <div>\r\n            {!isAuth() ? <Redirect to='/' /> : null}\r\n            {localStorage.getItem('onceWelcome')==1?\r\n                <div style={{\r\n                    position: \"absolute\",\r\n                    margin: \"0px\",\r\n                    width: \"100%\",\r\n                    height: \"100%\",\r\n                    backgroundColor: \"cornflowerblue\",\r\n                    zIndex: \"2\"\r\n                }}className=\"transition10\">\r\n                    <h1 style={{\r\n                        position: \"relative\",\r\n                        top: \"30%\",\r\n                        textAlign: \"center\",\r\n                        fontSize: \"100px\",\r\n                        fontWeight: \"2100\"\r\n                    }} className=\"transition9\">\r\n                        Welcome,<br/><br/><br/>\r\n                        {username}\r\n                    </h1>\r\n\r\n\r\n                </div>:null}\r\n\r\n\r\n\r\n\r\n                <nav className=\"navbar navbar-dark bg-dark flex-container\" style={{opacity:\"0.8\",boxShadow:\"10px 10px 8px 10px LightSlateGray\"}}>\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n\r\n                    <span className=\"navbar-brand mb-0 h1\"><h1 style={{color:\"DeepSkyBlue\",position:\"relative\",marginBottom:\"0px\",fontSize:\"50px\",fontWeight:\"900\",fontFamily:\"Verdana\"}}><strong className=\"unselectable\">MoPlay</strong></h1></span>\r\n\r\n                    <div className=\"dropdown\">\r\n                     <button type=\"button\" className=\"btn btn-info\"  data-toggle=\"dropdown\" style={{display:\"flex\"}}><h1 style={{fontSize:\"30px\"}}>{username}</h1>&nbsp;&nbsp;<i className=\"fas fa-user-cog fa-3x\"/></button>\r\n                        <div className=\"dropdown-menu\"  style={{position:\"absolute\",width:\"100%\"}}>\r\n                            <a className=\"dropdown-item\" href=\"#\" onClick={()=>{signout()}}>Logout</a>\r\n                        </div>\r\n                    </div>\r\n\r\n        </nav>\r\n\r\n            <div className={getWelcome()?\"transition3\":\"\"} style={{width:\"100%\",height:\"100%\",position:\"relative\",display:\"flex\",flexWrap:\"wrap\"}}>\r\n\r\n              <Link to=\"/markdownPreview\"  title=\"Get the coded text!\">\r\n                <div className=\"appBox\">\r\n\r\n                    <img  src=\"data:image/png;base64,\" />\r\n                    <h1 style={{fontWeight: 'bold',fontSize:\"40px\"}}>Markdown Preview</h1>\r\n                </div>\r\n              </Link>\r\n                <Link to=\"/calculator\"  title=\"Do your calculations!\">\r\n                <div className=\"appBox\">\r\n            <img  src=\"https://img.icons8.com/cotton/100/000000/calculator--v2.png\"/>\r\n                    <h1 style={{fontWeight: 'bold',fontSize:\"40px\",marginTop:\"10px\"}}>JS Calculator</h1>\r\n                </div>\r\n                </Link>\r\n                <Link to=\"/randomQuote\" title=\"Get your daily motivational quote!\">\r\n                <div className=\"appBox\">\r\n                <img src=\"https://img.icons8.com/doodle/100/000000/quote.png\"/>\r\n                    <h1 style={{fontWeight: 'bold',fontSize:\"40px\"}}>Quote of the day</h1>\r\n                </div>\r\n                </Link